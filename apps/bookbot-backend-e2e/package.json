{
  "name": "@bookbot/bookbot-backend-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@bookbot/bookbot-backend"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/bookbot-backend-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@bookbot/bookbot-backend:build",
          "@bookbot/bookbot-backend:serve"
        ]
      }
    }
  }
}
